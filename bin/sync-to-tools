#!/usr/bin/env bash
# Syncs ~/.agents/ (source of truth) into Factory and Cursor.
# Idempotent — safe to re-run anytime.
#
# Usage: sync-to-tools [--dry-run] [--quiet]
#
# What syncs (all auto-discovered, no hardcoded lists):
#   mcp.json         → symlink to both tools
#   skills/*/        → file-level symlinks (avoids tool-managed files in .agents/)
#   sub-agents/*.md  → symlinks to Factory, real files in Cursor
#   commands/        → directory-level symlinks to both tools
#   AGENTS.md        → Factory symlink + Cursor .mdc rule
#   rules/*.md       → Factory symlink + Cursor .mdc rule

set -euo pipefail

AGENTS="$HOME/.agents"
FACTORY="$HOME/.factory"
CURSOR="$HOME/.cursor"
CURSOR_SYNC_STATE_DIR="$CURSOR/.agents-sync"
CURSOR_AGENT_MANIFEST="$CURSOR_SYNC_STATE_DIR/managed-agents.txt"

DRY_RUN=false; QUIET=false
for arg in "$@"; do
    case "$arg" in
        --dry-run) DRY_RUN=true ;;
        --quiet)   QUIET=true ;;
        --help)    cat <<'HELP'
Syncs ~/.agents/ into Factory and Cursor tool directories.
Idempotent — safe to re-run anytime.

Usage: sync-to-tools [--dry-run] [--quiet]
  --dry-run   Show what would change without modifying anything
  --quiet     Suppress non-error output
HELP
                   exit 0 ;;
    esac
done

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; DIM='\033[2m'; BOLD='\033[1m'; NC='\033[0m'
changed=0; skipped=0; warnings=0

log_header() { $QUIET || echo -e "${BOLD}$1${NC}"; }
log_sync() { $QUIET || echo -e "  ${GREEN}✓${NC} $1"; ((changed++)) || true; }
log_skip() { $QUIET || echo -e "  ${DIM}– $1${NC}"; ((skipped++)) || true; }
log_warn() { echo -e "  ${YELLOW}⚠${NC} $1"; ((warnings++)) || true; }

remove_path() {
    local path="$1" label="$2"
    if $DRY_RUN; then
        log_sync "$label (dry-run, would remove stale artifact)"
        return
    fi
    rm -f "$path"
    log_sync "$label (removed stale artifact)"
}

ensure_symlink() {
    local src="$1" dst="$2" label="$3"
    if [[ -L "$dst" ]]; then
        local target
        target=$(readlink "$dst")
        if [[ "$target" == "$src" ]]; then
            log_skip "$label"
            return
        fi
        if $DRY_RUN; then
            log_sync "$label (dry-run, would repoint symlink)"
            return
        fi
        rm "$dst"
        ln -s "$src" "$dst"
        log_sync "$label (repointed symlink)"
        return
    elif [[ -d "$dst" && ! -L "$dst" ]]; then
        if $DRY_RUN; then
            log_sync "$label (dry-run, would replace dir with symlink)"
            return
        fi
        mv "$dst" "${dst}.bak"
        ln -s "$src" "$dst"
        log_sync "$label (replaced dir → .bak)"
        return
    elif [[ -f "$dst" ]]; then
        if $DRY_RUN; then
            log_sync "$label (dry-run, would replace file with symlink)"
            return
        fi
        cp "$dst" "${dst}.bak"
        rm "$dst"
        ln -s "$src" "$dst"
        log_sync "$label (replaced file, backup at .bak)"
        return
    fi
    if $DRY_RUN; then
        log_sync "$label (dry-run)"
        return
    fi
    mkdir -p "$(dirname "$dst")"
    ln -s "$src" "$dst"
    log_sync "$label"
}

copy_file() {
    local src="$1" dst="$2" label="$3"
    local note=""
    if [[ -L "$dst" ]]; then
        note=" (replaced symlink with file copy)"
    elif [[ -f "$dst" ]] && cmp -s "$src" "$dst"; then
        log_skip "$label"
        return
    elif [[ -f "$dst" ]]; then
        note=" (updated file copy)"
    fi
    if $DRY_RUN; then
        log_sync "$label (dry-run, would write real file)"
        return
    fi
    mkdir -p "$(dirname "$dst")"
    rm -f "$dst"
    cp "$src" "$dst"
    log_sync "$label$note"
}

prune_stale_symlinks() {
    local dst_dir="$1" src_prefix="$2" label_prefix="$3"
    local entry target name
    [[ -d "$dst_dir" ]] || return 0
    shopt -s nullglob
    for entry in "$dst_dir"/*; do
        [[ -L "$entry" ]] || continue
        target=$(readlink "$entry")
        [[ "$target" == "$src_prefix"* ]] || continue
        [[ -e "$target" ]] && continue
        name=$(basename "$entry")
        remove_path "$entry" "$label_prefix$name"
    done
    shopt -u nullglob
}

prune_manifest_managed_files() {
    local manifest="$1" target_dir="$2" current_names="$3" label_prefix="$4"
    local name
    [[ -f "$manifest" ]] || return 0
    while IFS= read -r name; do
        [[ -n "$name" ]] || continue
        if ! grep -Fxq "$name" "$current_names" 2>/dev/null; then
            remove_path "$target_dir/$name" "$label_prefix$name"
        fi
    done < "$manifest"
}

write_if_changed() {
    local dst="$1" content="$2" label="$3"
    local tmp
    tmp=$(mktemp "${TMPDIR:-/tmp}/sync-tools.XXXXXX")
    printf '%s\n' "$content" > "$tmp"
    if [[ -f "$dst" ]] && diff -q "$tmp" "$dst" >/dev/null 2>&1; then
        log_skip "$label"
        rm -f "$tmp"
        return
    fi
    if $DRY_RUN; then
        log_sync "$label (dry-run)"
        rm -f "$tmp"
        return
    fi
    mkdir -p "$(dirname "$dst")"
    mv "$tmp" "$dst"
    log_sync "$label"
}

prune_generated_cursor_rule_files() {
    local dst_dir="$1" entry name
    [[ -d "$dst_dir" ]] || return 0
    shopt -s nullglob
    for entry in "$dst_dir"/*.mdc; do
        [[ -f "$entry" ]] || continue
        name=$(basename "$entry" .mdc)
        [[ "$name" == "personal-coding-standards" ]] && continue
        [[ -f "$AGENTS/rules/$name.md" ]] && continue
        if grep -q "from ~/.agents/rules/" "$entry" 2>/dev/null; then
            remove_path "$entry" ".cursor/rules/$name.mdc"
        fi
    done
    shopt -u nullglob
}

log_header "Syncing ~/.agents/ → tools"
$DRY_RUN && ! $QUIET && echo -e "${DIM}(dry-run — no files will be written)${NC}"
$QUIET || echo ""

# ── 1. MCP Config ────────────────────────────────────────────
log_header "MCP Config"
ensure_symlink "$AGENTS/mcp.json" "$FACTORY/mcp.json" ".factory/mcp.json"
ensure_symlink "$AGENTS/mcp.json" "$CURSOR/mcp.json"  ".cursor/mcp.json"
$QUIET || echo ""

# ── 2. Skills (file-level symlinks per skill directory) ──────
# File-level avoids Cursor/Factory writing tool-managed files into .agents/
log_header "Skills"
mkdir -p "$FACTORY/skills" "$CURSOR/skills-cursor" 2>/dev/null || true
for skill_dir in "$AGENTS/skills"/*/; do
    [[ -d "$skill_dir" ]] || continue
    name=$(basename "$skill_dir")
    ensure_symlink "$skill_dir" "$FACTORY/skills/$name" ".factory/skills/$name"
    ensure_symlink "$skill_dir" "$CURSOR/skills-cursor/$name" ".cursor/skills-cursor/$name"
done
prune_stale_symlinks "$FACTORY/skills" "$AGENTS/skills/" ".factory/skills/"
prune_stale_symlinks "$CURSOR/skills-cursor" "$AGENTS/skills/" ".cursor/skills-cursor/"
$QUIET || echo ""

# ── 3. Sub-agents (Factory uses symlinks; Cursor uses real files) ─
log_header "Sub-agents"
current_cursor_agents=$(mktemp "${TMPDIR:-/tmp}/cursor-agents.XXXXXX")
for agent_file in "$AGENTS/sub-agents"/*.md; do
    [[ -f "$agent_file" ]] || continue
    name=$(basename "$agent_file")
    ensure_symlink "$agent_file" "$FACTORY/droids/$name" ".factory/droids/$name"
    copy_file "$agent_file" "$CURSOR/agents/$name" ".cursor/agents/$name"
    printf '%s\n' "$name" >> "$current_cursor_agents"
done
prune_stale_symlinks "$FACTORY/droids" "$AGENTS/sub-agents/" ".factory/droids/"
prune_manifest_managed_files "$CURSOR_AGENT_MANIFEST" "$CURSOR/agents" "$current_cursor_agents" ".cursor/agents/"
if [[ -s "$current_cursor_agents" ]]; then
    mkdir -p "$CURSOR_SYNC_STATE_DIR"
    write_if_changed "$CURSOR_AGENT_MANIFEST" "$(cat "$current_cursor_agents")" \
        ".cursor/.agents-sync/managed-agents.txt"
else
    remove_path "$CURSOR_AGENT_MANIFEST" ".cursor/.agents-sync/managed-agents.txt"
fi
rm -f "$current_cursor_agents"
$QUIET || echo ""

# ── 4. Commands (directory-level symlinks) ────────────────────
if [[ -d "$AGENTS/commands" ]]; then
    log_header "Commands"
    ensure_symlink "$AGENTS/commands" "$CURSOR/commands" ".cursor/commands → .agents/commands"
    ensure_symlink "$AGENTS/commands" "$FACTORY/commands" ".factory/commands → .agents/commands"
    $QUIET || echo ""
fi

# ── 5. AGENTS.md (coding standards) ─────────────────────────
log_header "Coding Standards"
mkdir -p "$FACTORY/rules" "$CURSOR/rules" 2>/dev/null || true

ensure_symlink "$AGENTS/AGENTS.md" "$FACTORY/rules/coding-standards.md" \
    ".factory/rules/coding-standards.md"

if [[ -f "$AGENTS/AGENTS.md" ]]; then
    body=$(< "$AGENTS/AGENTS.md")
    mdc="---
description: Personal coding standards (from ~/.agents/AGENTS.md)
alwaysApply: true
---

$body"
    write_if_changed "$CURSOR/rules/personal-coding-standards.mdc" "$mdc" \
        ".cursor/rules/personal-coding-standards.mdc"
fi
$QUIET || echo ""

# ── 6. Rules (auto-discovered) ───────────────────────────────
if ls "$AGENTS/rules"/*.md >/dev/null 2>&1; then
    log_header "Rules"
    for rule_file in "$AGENTS/rules"/*.md; do
        [[ -f "$rule_file" ]] || continue
        name=$(basename "$rule_file" .md)
        ensure_symlink "$rule_file" "$FACTORY/rules/$name.md" ".factory/rules/$name.md"
        rule_body=$(< "$rule_file")
        mdc="---
description: $name (from ~/.agents/rules/)
alwaysApply: true
---

$rule_body"
        write_if_changed "$CURSOR/rules/$name.mdc" "$mdc" ".cursor/rules/$name.mdc"
    done
    $QUIET || echo ""
fi
prune_stale_symlinks "$FACTORY/rules" "$AGENTS/rules/" ".factory/rules/"
prune_generated_cursor_rule_files "$CURSOR/rules"

# ── Summary ──────────────────────────────────────────────────
if $QUIET; then
    [[ $changed -gt 0 ]] && echo -e "${GREEN}sync-to-tools:${NC} $changed synced" || true
else
    echo -e "${BOLD}Done.${NC} ${GREEN}$changed synced${NC} · $skipped unchanged · ${YELLOW}$warnings warnings${NC}"
fi
